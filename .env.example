# ============================================================
# Multi-Cloud ML Pipeline Orchestrator — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- AWS (SageMaker) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_SAGEMAKER_ROLE_ARN=arn:aws:iam::role/SageMakerExecutionRole
AWS_S3_BUCKET=your-ml-bucket

# --- GCP (Vertex AI) ---
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account.json
GCP_STAGING_BUCKET=gs://your-staging-bucket

# --- Azure (Azure ML) ---
AZURE_SUBSCRIPTION_ID=your-azure-subscription
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_WORKSPACE_NAME=your-ml-workspace
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# --- Prefect ---
PREFECT_API_URL=http://localhost:4200/api

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5050
DASHBOARD_SECRET_KEY=change-me-in-production

# --- Cost Optimization ---
COST_STRATEGY=cheapest
# Options: cheapest, balanced, geographic, round_robin
SPOT_INSTANCE_PREFERENCE=true
MAX_BUDGET_PER_JOB=50.00
